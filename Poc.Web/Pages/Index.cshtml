@page
@model IndexModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "Home page";
}

<div class="kpi-dashboard-row">
    <total-messages-card data="Model.MessagesTotalDto" />

    @foreach (var kpiGroup in Model.KpiGroups)
    {
        <kpi-card data="kpiGroup"/>
    }
</div>

<component type="typeof(Poc.RCL.Components.MessagesGrid)" 
           render-mode="Static" 
           param-Data="Model.Messages" />

@section Scripts {
    <script>
        // Oggetto principale per la gestione della pagina
        const Dashboard = {
            // Proprietà per mantenere il riferimento alla connessione SignalR
            signalrConnection: null,

            // 1. Inizializzazione di tutti i moduli della pagina
            init() {
                console.log("Inizializzazione Dashboard in corso...");
                this.initSignalR();
                this.initEventListeners();
            },

            // 2. Gestione della connessione SignalR
            initSignalR() {
                this.signalrConnection = new signalR.HubConnectionBuilder()
                    .withUrl("/hubs/messagegrid")
                    .build();

                // Ascolto dei messaggi di ritorno dal Server
                this.signalrConnection.on("ReceiveFilteredMessages", (filteredData) => {
                    this.updateDataGrid(filteredData);
                });

                // Avvio della connessione
                this.signalrConnection.start()
                    .then(() => console.log("Dashboard: Connesso a SignalR con successo!"))
                    .catch(err => console.error("Errore connessione SignalR:", err.toString()));
            },

            // 3. Registrazione di tutti i Listener di eventi JavaScript
            initEventListeners() {
                // Intercettiamo l'evento personalizzato lanciato dai componenti Blazor (KPI cards)
                document.addEventListener("kpi-card-filter", (e) => {
                    const datiFiltro = e.detail;
                    console.log("Dashboard: Intercettato click sulle KPI", datiFiltro);
                    
                    if (datiFiltro && datiFiltro.types) {
                        this.filterMessages(datiFiltro.types);
                    }
                });
            },

            // 4. Azione: Invia i filtri al server tramite SignalR
            filterMessages(typesArray) {
                if (!this.signalrConnection) return;
                
                // Flattando l'array del attributo Code
                const flatCodeArray = Array.isArray(typesArray) ? typesArray.flat() : [];

                this.signalrConnection.invoke("FilterMessages", flatCodeArray)
                    .catch(err => console.error("Errore durante il filtraggio:", err.toString()));
            },

            // 5. Azione: Ripulire i filtri (invocata dal bottone Clear Filter nell'HTML)
            clearFilter() {
                console.log("Dashboard: Reset dei filtri richiesto.");
                this.filterMessages([]);
            },

            // 6. UI: Aggiornamento della Griglia DevExtreme e dei contatori
            updateDataGrid(filteredData) {
                console.log("Dashboard: Aggiornamento griglia con nuovi dati", filteredData);
                
                const dataGrid = $("#messages-grid").dxDataGrid("instance");
                if (dataGrid) {
                    dataGrid.option("dataSource", filteredData);
                    $("#grid-count").text(filteredData.length);
                } else {
                    console.warn("Dashboard: Istanza dxDataGrid non trovata.");
                }
            }
        };

        // Avviamo la dashboard non appena la pagina è pronta
        $(document).ready(() => {
            Dashboard.init();
        });

        // Mappa la funzione globale richiesta dal bottone HTML al metodo dell'oggetto
        function clearGridFilter() {
            console.log("Global Clear: Invocazione reset filtri tramite Dashboard");
            Dashboard.clearFilter();
        }
    </script>
}
