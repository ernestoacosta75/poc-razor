@page
@model IndexModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "Home page";
}

<div class="kpi-dashboard-row">
    <total-messages-card data="Model.MessagesTotalDto" />

    @foreach (var kpiGroup in Model.KpiGroups)
    {
        <kpi-card data="kpiGroup" />
    }
</div>

<messages-grid data="Model.Messages" filter-url="/Index?handler=FilteredMessages" />
