@page "/"
@inject IKpiService KpiService

@* AGGIUNGI QUESTI USING IN CIMA PER FAR ABILITARE LE KPI CARD DELLA LIBRERIA *@
@using Poc.RCL.Components
@using Poc.RCL.Models

<div class="kpi-dashboard-row">
    @if (MessagesTotalDto != null)
    {
        <TotalMessagesCard Data="@MessagesTotalDto" />
    }

    @foreach (var kpiGroup in KpiGroups)
    {
        <KpiCard Data="@kpiGroup" OnFilterSelected="ApplicaFiltro" />
    }
</div>

<div class="messages-grid-wrapper">

    <div class="messages-grid-toolbar">
        <span class="messages-grid-count">
            @* Corretto il conteggio dinamico *@
            Showing <strong>@FilteredMessages.Count</strong> of <strong>@Messages.Count</strong> messages
        </span>

        <button class="messages-grid-sort-btn" @onclick="ToggleSyncDateSort">
            <i class="bi bi-filter"></i> Sync Date <span>@(IsDescending ? "↓" : "↑")</span>
        </button>

        <button class="messages-grid-clear-btn" @onclick="ClearGridFilter">
            <i class="bi bi-x-circle"></i> Clear filter
        </button>
    </div>

    <DxGrid Data="@FilteredMessages" PageSize="10" CssClass="w-100 shadow-sm rounded">
        <Columns>
            <DxGridDataColumn FieldName="VesselName" Caption="VESSEL">
                <CellDisplayTemplate>
                    @{
                        var d = (MessageDto)context.DataItem;
                    }
                    <div style="display:flex; align-items:center; gap:10px; padding:4px 0;">
                        <div style="width:38px; height:38px; border-radius:8px; background:@d.VesselColor; color:#fff; font-weight:700; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                            @d.VesselInitials
                        </div>
                        <div>
                            <div style="font-weight:600; font-size:13px;">@d.VesselName</div>
                            <div style="font-size:11px; color:#6b7280;">@d.CaptainEmail</div>
                        </div>
                    </div>
                </CellDisplayTemplate>
            </DxGridDataColumn>

            <DxGridDataColumn FieldName="VoyageCode" Caption="VOYAGE" Width="110px" Alignment="GridCellAlignment.Center">
                <CellDisplayTemplate>
                    @{
                        var d = (MessageDto)context.DataItem;
                    }
                    <span style="background:#fef9c3; color:#854d0e; border:1px solid #fde047; border-radius:4px; padding:3px 8px; font-size:12px; font-weight:600;">
                        @d.VoyageCode
                    </span>
                </CellDisplayTemplate>
            </DxGridDataColumn>

            <DxGridDataColumn FieldName="MessageType" Caption="TYPE" Width="155px" Alignment="GridCellAlignment.Center">
                <CellDisplayTemplate>
                    @{ var d = (MessageDto)context.DataItem; }
                    <span style="border-radius:20px; padding:4px 12px; font-size:12px; font-weight:600; background-color: #f3f4f6;">
                        @d.MessageType.ToUpper()
                    </span>
                </CellDisplayTemplate>
            </DxGridDataColumn>

            <DxGridDataColumn FieldName="MessageDate" Caption="MESSAGE DATE" Width="170px" DisplayFormat="dd/MM/yyyy HH:mm" />

            <DxGridDataColumn FieldName="FromPort" Caption="ROUTE">
                <CellDisplayTemplate>
                    @{
                        var d = (MessageDto)context.DataItem;
                    }
                    <div style="font-size:13px;">
                        <i class="bi bi-ship text-muted me-1"></i> @d.FromPort → @d.ToPort
                    </div>
                </CellDisplayTemplate>
            </DxGridDataColumn>
        </Columns>
    </DxGrid>
</div>
