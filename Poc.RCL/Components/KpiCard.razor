@using Poc.RCL.Models
@using System.Text.Json
@{
    var allCodes = Data.Metrics.SelectMany(m => m.Code).ToArray();
    var codesJson = JsonSerializer.Serialize(allCodes);
}

<div class="kpi-card" style="border-left: 5px solid @Data.AccentColor">

    <a href="javascript:void(0);"
       data-codes='@codesJson'
       onclick="window.FilterMessagesGrid(this);"
       class="kpi-card-header"
       style="cursor:pointer; text-decoration: none; color: inherit; display: flex; align-items: center;">
        <div class="kpi-header-icon" style="background-color: @(Data.AccentColor)1A; color: @Data.AccentColor;">
            <i class="@Data.HeaderIcon"></i>
        </div>
        <span class="kpi-card-title">@Data.Title.ToUpper()</span>
    </a>

    @if (Data.IsGrid)
    {
        <div class="kpi-grid-2-columns">
            @foreach (var metric in Data.Metrics)
            {
                <MetricKpiItem Item="metric" IconColor="@Data.AccentColor" />
            }
        </div>
    }
    else
    {
        <div class="kpi-card-body">
            @foreach (var metric in Data.Metrics)
            {
                <MetricKpiItem Item="metric" IconColor="@Data.AccentColor" />
            }
        </div>
    }
</div>
