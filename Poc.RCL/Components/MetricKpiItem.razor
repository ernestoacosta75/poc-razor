<div class="kpi-metric-row"
     style="cursor:pointer;"
     @onclick="() => OnFilter.InvokeAsync(Item.Code)"
     @onclick:stopPropagation="true">
    <i class="@Item.Icon kpi-icon" style="color: @(string.IsNullOrEmpty(IconColor) ? "currentColor" : IconColor) !important;"></i>
    <span class="kpi-value">@Item.Value</span>
    <span class="kpi-label">@Item.Label</span>
</div>
