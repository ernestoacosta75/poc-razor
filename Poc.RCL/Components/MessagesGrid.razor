@using Poc.RCL.Models
@using System.Text.Json

@{
    var _jsonOptions = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase };
    var initialDataJson = JsonSerializer.Serialize(Data ?? new List<MessageDto>(), _jsonOptions);
    var columnsJson = JsonSerializer.Serialize(Columns ?? new List<GridColumnDto>(), _jsonOptions);
    var total = Data?.Count ?? 0;
}

<div class="messages-grid-wrapper" style="border: none; box-shadow: none; position: relative; min-height: 200px;">

    <div class="messages-grid-toolbar">
        <span class="messages-grid-count">
            Showing <strong id="@(_gridId + "-visible")">@total</strong>
            of <strong>@total</strong> messages
        </span>
        <button class="messages-grid-sort-btn" onclick="window['MsgGrid_@(_gridId)'].toggleSort()">
            <i class="bi bi-filter"></i> Sync Date
            <span id="@(_gridId + "-sort-arrow")">↓</span>
        </button>
        <a href="javascript:void(0);"
           data-codes='[]'
           onclick="window.FilterMessagesGrid(this);"
           class="messages-grid-clear-btn" style="text-decoration: none; cursor: pointer;" title="Clear filter">
            <i class="bi bi-x-circle"></i> Clear filter
        </a>
    </div>

    <div id="@_gridId"></div>

</div>

<script>
    (function () {
        window.FilterMessagesGrid = function (element) {
            // Questo cercherà l'elemento con quell'id nel DOM e lo "avvolge"
            // in un oggetto jQuery con dei metodi aggiuntivi
            const gridElement = $("#@_gridId");
            if (!gridElement.length) return;

            // Restituisce l'istanza JavaScript della griglia già inizializzata
            const gridInstance = gridElement.dxDataGrid("instance");

            // Converte l'elemento cliccato in un oggetto jQuery.
            // .data("codes") legge l'attributo data-codes dall'html e lo converte 
            // da string JSON ad array.
            const targetTypes = $(element).data("codes") || [];

            // Questo riga permette eseguire lo spinner nativo dispatchEvent DevExtreme
            if (gridInstance) gridInstance.beginCustomLoading("Filtering...");

            // Costruendo la url della richiesta AJAX, aggiungendo i parametri "types" per ogni tipo selezionato.
            let url = "/Index?handler=FilteredMessages";
            if (targetTypes.length > 0) {
                url += "&" + targetTypes.map(t => `types=${encodeURIComponent(t)}`).join("&");
            }

            $.ajax({
                url: url,
                type: "GET",
                dataType: "json",
                success: function (newMessages) {
                    // Aggiornamento righe della griglia con i nuovi dati filtrati
                    if (gridInstance) gridInstance.option("dataSource", newMessages);
                    
                    // Selettore jQuery per attributo id, per aggiornare il contatore dei messaggi visibili
                    $("[id='@(_gridId)-visible']").text(newMessages.length);
                },
                error: function (xhr, status, error) { console.error("Errore AJAX:", error); },
                // Stop esecuzione dello spinner nativo DevExtreme dopo il completamento della richiesta
                complete: function () { if (gridInstance) gridInstance.endCustomLoading(); }
            });
        };

        // Inizializzazione della griglia DevExtreme al caricamento del documento
        // @((MarkupString)columnsJson) è Razor: scrive il JSON delle colonne direttamente nell'HTML.
        // Il risultato sar' un array JSON letterale
        $(document).ready(function () {
            const processedColumns = (@((MarkupString)columnsJson)).map(col => {
                col.name = col.caption;
                if (!col.templateType) return col;

                const cfg = {
                    type: col.templateType, 
                    colorFld: col.avatarColorField, 
                    textFld: col.avatarTextField, 
                    subFld: col.subTitleField,
                    bg: col.badgeBackgroundColor, 
                    txt: col.badgeTextColor, 
                    iconFld: col.iconField, 
                    toPortFld: col.toPortField,
                    routeTypeFld: col.routeTypeField, 
                    timeFld: col.timeField, 
                    syncFld: col.syncDateField
                };

                // Callback che DevExtreme chiama per ogni cella della colonna corrispondente
                col.cellTemplate = function(container, cellInfo) {
                    if (!cellInfo.data) return;
                    const html = CellRenderers[cfg.type](cellInfo.value || "", cellInfo.data, cfg);
                    $(container).html(html);
                };

                delete col.templateType;
                return col;
            });

            // Inizializzazione della griglia DevExtreme con le colonne elaborate e i dati iniziali
            $("#@_gridId").dxDataGrid({
                dataSource: @((MarkupString)initialDataJson),
                columns: processedColumns,
                showBorders: false, 
                showRowLines: true, 
                headerFilter: { visible: false }, 
                filterRow: { visible: false },
                paging: { pageSize: 10 },
                pager: { 
                    visible: true, 
                    allowedPageSizes: [10, 20, 50, 100], 
                    showPageSizeSelector: true, 
                    showInfo: true, 
                    showNavigationButtons: true 
                },
                scrolling: { mode: "standard" }, 
                selection: { 
                    mode: "multiple", 
                    showCheckBoxesMode: "always" 
                }
            });
        });
    })();
</script>