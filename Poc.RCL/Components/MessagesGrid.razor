@using Poc.RCL.Models
@using System.Text.Json

@{
    var _jsonOptions = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase };
    var initialDataJson = JsonSerializer.Serialize(Data ?? new List<MessageDto>(), _jsonOptions);
    var total = Data?.Count ?? 0;
}

<div class="messages-grid-wrapper" style="border: none; box-shadow: none; position: relative; min-height: 200px;">

    <div class="messages-grid-toolbar">
        <span class="messages-grid-count">
            Showing <strong id="@(_gridId + "-visible")">@total</strong>
            of <strong>@total</strong> messages
        </span>
        <button class="messages-grid-sort-btn" onclick="window['MsgGrid_@(_gridId)'].toggleSort()">
            <i class="bi bi-filter"></i> Sync Date
            <span id="@(_gridId + "-sort-arrow")">↓</span>
        </button>
        <a href="javascript:void(0);"
           data-codes='[]'
           onclick="window.FilterMessagesGrid(this);"
           class="messages-grid-clear-btn" style="text-decoration: none; cursor: pointer;" title="Clear filter">
            <i class="bi bi-x-circle"></i> Clear filter
        </a>
    </div>

    <div id="@_gridId"></div>

</div>

<script>
    (function () {
        // Dizionario statico per il rendering nella cella di TYPE
        const TYPE_PILL_THEMES = {
            "SAILING": { bg: "#e0f2fe", text: "#0284c7", icon: "bi-water" },
            "BERTHING": { bg: "#eff6ff", text: "#1e40af", icon: "bi-pin" },
            "AT SEA": { bg: "#f3e8ff", text: "#6b21a8", icon: "bi-waves" },
            "AT PORT": { bg: "#f3e8ff", text: "#6b21a8", icon: "bi-building" },
            "COSP": { bg: "#06b6d41A", text: "#00838f", icon: "bi-play-circle-fill" },
            "EOSP": { bg: "#e0f7fa", text: "#00838f", icon: "bi-record-circle-fill" },
            "TRANSIT": { bg: "#e8eaf6", text: "#283593", icon: "bi-arrow-left-right" },
            "REFUELING": { bg: "#fff3e0", text: "#ef6c00", icon: "bi-fuel-pump-fill" },
            "BUNKER": { bg: "#fff3e0", text: "#ef6c00", icon: "bi-plus-square" },
            "DELAY": { bg: "#e8f5e9", text: "#2e7d32", icon: "bi-hourglass-split" },
            "EGCS": { bg: "#e8f5e9", text: "#2e7d32", icon: "bi-wind" },
            "SLUDGE": { bg: "#f5f5f5", text: "#424242", icon: "bi-trash" },
            "DISCHARGED": { bg: "#f5f5f5", text: "#424242", icon: "bi-trash" },
            "SURVEY": { bg: "#e8f5e9", text: "#2e7d32", icon: "bi-clipboard-check" }
        };

        let activeFilters = [];

        // Funzione di filtraggio AJAX globale
        window.FilterMessagesGrid = function (element) {
            const gridElement = $("#@_gridId");
            if (!gridElement.length) return;

            const gridInstance = gridElement.dxDataGrid("instance");
            // Codici passati dalla card (es. ["SAILING"] o ["COSP", "COSP TRANSIT"])
            const targetTypes = $(element).data("codes") || [];

            if (typeof msgGridLoadPanel !== 'undefined' && msgGridLoadPanel) msgGridLoadPanel.show();

            // Logica di deactivation dei filtri:
            // Se l'array è vuoto (pulsante "Clear Filter") oppure se si tratta di un filtro già attivo, svuotare
            if (targetTypes.length === 0 || JSON.stringify(activeFilters) === JSON.stringify(targetTypes)) {
                activeFilters = []; // Resetta i filtri attivi
                // Rimuovere effetto visivo di selezione "active" da tutte le card
                $(".deactivation-card-class").removeClass("active-filter-style");
            } else {
                activeFilters = targetTypes; 
                $(".deactivation-card-class").removeClass("active-filter-style");
                $(element).addClass("active-filter-style");
            }

            if (gridInstance) gridInstance.beginCustomLoading("Filtering...");

            // Construzione dell'URL dinamico per il backend
            let url = "/Index?handler=FilteredMessages";
            if (activeFilters.length > 0) {
                url += "&" + activeFilters.map(t => `types=${encodeURIComponent(t)}`).join("&");
            }

            $.ajax({
                url: url,
                type: "GET",
                dataType: "json",
                success: function (newMessages) {
                    if (gridInstance) {
                        gridInstance.option("dataSource", newMessages);
                        gridInstance.refresh();
                    }
                    $("[id='@(_gridId)-visible']").text(newMessages.length);
                },
                error: function (xhr, status, error) {
                    console.error("Errore durante il filtraggio AJAX:", error);
                },
                complete: function () { if (gridInstance) gridInstance.endCustomLoading(); }
            });
        };

        $(document).ready(function () {
            // Inizializzazione dello Spinner
            window.msgGridLoadPanel = $("#grid-loadpanel").dxLoadPanel({
                shading: true, shadingColor: "rgba(255, 255, 255, 0.7)",
                position: { my: "center", at: "center", of: ".messages-grid-wrapper" },
                visible: false, showIndicator: true, showPanel: true, text: "Loading messages...",
                container: ".messages-grid-wrapper", zIndex: 99999
            }).dxLoadPanel("instance");

            // Inizializzazione DevExtreme DataGrid con i template INLINE
            $("#@_gridId").dxDataGrid({
                dataSource: @((MarkupString)initialDataJson),
                showBorders: false,
                showRowLines: true,
                headerFilter: { visible: false },
                filterRow: { visible: false },
                paging: { pageSize: 10 },
                pager: { visible: true, allowedPageSizes: [10, 20, 50, 100], showPageSizeSelector: true, showInfo: true, showNavigationButtons: true },
                scrolling: { mode: "standard" },
                selection: { mode: "multiple", showCheckBoxesMode: "always" },

                columns: [
                    {
                        dataField: "vesselName",
                        caption: "VESSEL",
                        cellTemplate: function (container, cellInfo) {
                            const data = cellInfo.data;
                            if (!data) return;

                            const val = cellInfo.value || "";
                            const color = data.vesselColor || "#6b7280";
                            const initials = data.vesselInitials || "";
                            const subText = data.captainEmail || "";

                            $(container).html(`
                                <div style="display:flex; align-items:center; gap:10px; padding:4px 0;">
                                    <div style="width:38px; height:38px; border-radius:8px; background:${color}; color:#fff; font-weight:700; font-size:12px; display:flex; align-items:center; justify-content:center; flex-shrink:0;">${initials}</div>
                                    <div>
                                        <div style="font-weight:600; font-size:13px; color:#111827;">${val}</div>
                                        <div style="font-size:11px; color:#6b7280;">${subText}</div>
                                    </div>
                                </div>
                            `);
                        }
                    },
                    {
                        dataField: "voyage",
                        caption: "VOYAGE",
                        alignment: "center",
                        cellTemplate: function (container, cellInfo) {
                            const data = cellInfo.data;
                            if (!data) return;

                            const val = cellInfo.value || data.voyageCode || data.voyageNo || "";
                            if (!val) return;

                            $(container).html(`
                                <span style="background:#fef08a; color:#854d0e; border-radius:4px; padding:4px 8px; font-size:11px; font-weight:700; display:inline-block;">
                                    ${val.toUpperCase()}
                                </span>
                            `);
                        }
                    },
                    {
                        dataField: "type",
                        caption: "TYPE",
                        cellTemplate: function (container, cellInfo) {
                            const data = cellInfo.data;
                            if (!data) return;

                            const val = cellInfo.value || data.messageTypeDesc || data.typeDesc || "";
                            if (!val) return;

                            const key = Object.keys(TYPE_PILL_THEMES).find(k => val.trim().toUpperCase().includes(k)) || "";
                            const theme = TYPE_PILL_THEMES[key] || { bg: "#e5e7eb", text: "#1f2937", icon: "bi-chat-left-text" };

                            $(container).html(`
                                <span style="background:${theme.bg}; color:${theme.text}; border-radius:20px; padding:4px 14px; font-size:11px; font-weight:700; display:inline-flex; align-items:center; gap:6px; font-family: sans-serif; letter-spacing: 0.3px; box-shadow: 0 1px 2px rgba(0,0,0,0.02);">
                                    <i class="bi ${theme.icon}" style="font-size:12px; display: flex; align-items: center;"></i>
                                    <span>${val.toUpperCase()}</span>
                                </span>
                            `);
                        }
                    },
                    {
                        dataField: "messageDate",
                        caption: "DATE",
                        cellTemplate: function (container, cellInfo) {
                            const data = cellInfo.data;
                            if (!data) return;

                            const dateObj = new Date(cellInfo.value);
                            const day = !isNaN(dateObj) ? String(dateObj.getDate()).padStart(2, '0') : "20";
                            const month = !isNaN(dateObj) ? dateObj.toLocaleString('en-US', { month: 'short' }).toUpperCase() : "MAR";
                            const year = !isNaN(dateObj) ? dateObj.getFullYear() : "2026";
                            const time = data.messageTime || "10:30";
                            const syncDate = data.lastSyncDate || "20/03 12:15";

                            $(container).html(`
                                <div style="display:flex; flex-direction:column; gap:5px; padding:2px 0; font-family: sans-serif;">
                                    <div style="display:flex; align-items:center; gap:10px;">
                                        <span style="font-size:26px; font-weight:700; color:#d9a420; line-height:1; letter-spacing:-0.5px;">${day}</span>
                                        <div style="display:flex; flex-direction:column; line-height:1.1; justify-content:center;">
                                            <span style="font-size:12px; font-weight:700; color:#4a4a4a; letter-spacing:0.5px;">${month}</span>
                                            <span style="font-size:11px; font-weight:500; color:#9b9b9b;">${year}</span>
                                        </div>
                                        <span style="font-size:12px; font-weight:500; color:#595959; background:#e6e6e6; padding:3px 8px; border-radius:6px; margin-left:2px; font-variant-numeric: tabular-nums;">${time}</span>
                                    </div>
                                    <div style="display:flex; margin-top:2px;">
                                        <span style="background:#eaf7ff; color:#32b2f0; border:1px solid #cceeff; border-radius:6px; padding:2px 6px; font-size:11px; font-weight:700; display:inline-flex; align-items:center; gap:5px;">
                                            <i class="bi bi-arrow-repeat" style="font-size:12px; font-weight:bold;"></i> ${syncDate}
                                        </span>
                                    </div>
                                </div>
                            `);
                        }
                    },
                    {
                        dataField: "fromPort",
                        caption: "ROUTE",
                        width: 260,
                        minWidth: 240,
                        cellTemplate: function (container, cellInfo) {
                            const data = cellInfo.data;
                            if (!data) return;

                            const fromPort = cellInfo.value || "";
                            if (!fromPort) return;

                            const isTransit = fromPort.toUpperCase().includes("CANAL") ||
                                              fromPort.toUpperCase().includes("SUEZ") ||
                                              (data.type && data.type.toUpperCase().includes("TRANSIT"));

                            const toPort = data.toPort || "";
                            const hasDestination = toPort !== null && toPort !== undefined && String(toPort).trim() !== "";

                            const portLinkStyle = "color: #2563eb; text-decoration: none; font-weight: 700; cursor: pointer; white-space: nowrap;";

                            $(container).html(`
                                <div style="display:flex; align-items:center; gap:8px; font-size:12px; font-weight:700; font-family:sans-serif; padding:6px 0; white-space: nowrap; width: max-content;">
                                    <div style="display:flex; align-items:center; gap:5px; flex-shrink: 0;">
                                        ${isTransit ? `<i class="bi bi-arrow-left-right" style="color:#f59e0b; font-size:13px;"></i>` : `<i class="bi bi-geo-alt-fill" style="color:#f59e0b; font-size:14px;"></i>`}
                                        <span style="${isTransit ? 'color:#f59e0b;' : portLinkStyle}">${fromPort.toUpperCase()}</span>
                                    </div>
                                    ${hasDestination ? `
                                        <i class="bi bi-arrow-right" style="color:#94a3b8; font-size:14px; flex-shrink: 0;"></i>
                                        <div style="display:flex; align-items:center; gap:5px; flex-shrink: 0;">
                                            ${data.routeType === "land" ? `<i class="bi bi-triangle-fill" style="color:#eab308; font-size:9px;"></i>` : `<i class="bi bi-flag-fill" style="color:#eab308; font-size:13px;"></i>`}
                                            <span style="${portLinkStyle}">${toPort.toUpperCase()}</span>
                                        </div>
                                    ` : ''}
                                </div>
                            `);
                        }
                    },
                    {
                        dataField: "status",
                        caption: "STATUS",
                        alignment: "center",
                        cellTemplate: function(container, cellInfo) {
                            const val = cellInfo.value || "";
                            if (!val) return;
                            $(container).html(`
                                <span style="color: #16a34a; background: #f0fdf4; padding: 4px 12px; border-radius: 4px; font-size: 11px; font-weight: 600;">
                                    ${val}
                                </span>
                            `);
                        }
                    }
                ]
            });
        });
    })();
</script>
