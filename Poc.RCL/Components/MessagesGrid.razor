@using Poc.RCL.Models
@using System.Text.Json

@{
    var _jsonOptions = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase };
    var initialDataJson = JsonSerializer.Serialize(Data ?? new List<MessageDto>(), _jsonOptions);
    var total = Data?.Count ?? 0;
}

<div class="messages-grid-wrapper" style="border: none; box-shadow: none;">

    <div class="messages-grid-toolbar">
        <span class="messages-grid-count">
            Showing <strong id="@(_gridId + "-visible")">@total</strong>
            of <strong>@total</strong> messages
        </span>
        <button class="messages-grid-sort-btn" onclick="window['MsgGrid_@(_gridId)'].toggleSort()">
            <i class="bi bi-filter"></i> Sync Date
            <span id="@(_gridId + "-sort-arrow")">↓</span>
        </button>
        <button class="messages-grid-clear-btn" onclick="window['MsgGrid_@(_gridId)'].clearFilter()" title="Clear filter">
            <i class="bi bi-x-circle"></i> Clear filter
        </button>
    </div>

    <div id="@_gridId"></div>

</div>

<script>
    (function () {
        const gridId = "@_gridId";
        const filterUrl = "@FilterUrl";
        const allMessages = @((MarkupString)initialDataJson);
        let sortAsc = false;

        function getGrid() {
            return $("#" + gridId).dxDataGrid("instance");
        }

        function updateCount(n) {
            document.getElementById(gridId + "-visible").textContent = n;
        }

        function initGrid(data) {
            $("#" + gridId).dxDataGrid({
                dataSource: data,
                showBorders: false,
                showRowLines: true,
                showColumnLines: false,
                rowAlternationEnabled: false,
                headerFilter: { visible: false },
                filterRow: { visible: false },
                paging: { enabled: false },
                scrolling: { mode: "standard" },
                selection: { mode: "multiple", showCheckBoxesMode: "always" },
                columns: [
                    {
                        dataField: "vesselName", caption: "VESSEL", width: "25%",
                        cellTemplate: (el, ci) => cellRenderers.vessel(el, ci)
                    },
                    {
                        dataField: "voyageCode", caption: "VOYAGE", width: "15%", alignment: "center",
                        cellTemplate: (el, ci) => cellRenderers.voyage(el, ci)
                    },
                    {
                        dataField: "messageTypeDesc", caption: "TYPE", width: 160, alignment: "center",
                        cellTemplate: (el, ci) => cellRenderers.type(el, ci)
                    },
                    {
                        dataField: "messageDate", caption: "DATE", width: 170, dataType: "date",
                        cellTemplate: (el, ci) => cellRenderers.date(el, ci)
                    },
                    {
                        dataField: "fromPort", caption: "ROUTE", width: "35%",
                        cellTemplate: (el, ci) => cellRenderers.route(el, ci)
                    },
                    {
                        dataField: "messageTypeDesc", name: "statusColumn", caption: "STATUS", width: "15%", alignment: "center",
                        cellTemplate: (el, ci) => {
                            const val = ci.data?.messageTypeDesc || ci.data?.MessageTypeDesc || "";
                            $(el).html(`<span style="background:#dcfce7;color:#166534;border-radius:20px;
                                padding:3px 12px;font-size:11px;font-weight:600;">${val}</span>`);
                        }
                    },
                    {
                        dataField: "syncDate", visible: false,
                        sortOrder: "desc", sortIndex: 0
                    }
                ]
            });
            updateCount(data.length);
        }

        // API pubblica — chiamata da onclick nei KpiCard
        window["MsgGrid_" + gridId] = {
            filter: function (types) {
                if (!filterUrl || !types || types.length === 0) {
                    this.clearFilter();
                    return;
                }
                const flat = types.flat();
                const params = new URLSearchParams();
                flat.forEach(t => params.append("types", t));

                fetch(filterUrl + "&" + params.toString())
                    .then(r => r.json())
                    .then(data => {
                        getGrid().option("dataSource", data);
                        updateCount(data.length);
                    })
                    .catch(err => console.error("Errore filtro:", err));
            },

            clearFilter: function () {
                getGrid().option("dataSource", allMessages);
                updateCount(allMessages.length);
            },

            toggleSort: function () {
                sortAsc = !sortAsc;
                getGrid().columnOption("syncDate", "sortOrder", sortAsc ? "asc" : "desc");
                document.getElementById(gridId + "-sort-arrow").textContent = sortAsc ? "↑" : "↓";
            }
        };

        $(document).ready(function () {
            initGrid(allMessages);

            document.addEventListener("messages-grid-filter", function (e) {
                window["MsgGrid_" + gridId].filter(e.detail.types);
            });
        });
    })();
</script>
